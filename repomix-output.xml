#### 2. Mensajes de Error Genéricos

```typescript
// ✅ CORRECTO
async login(dto: LoginDto) {
    const user = await this.userRepository.findOneBy({ username: dto.username });
    
    if (!user || !(await bcrypt.compare(dto.password, user.password))) {
